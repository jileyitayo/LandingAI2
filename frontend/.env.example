# ===========================================
# SiteSmith Frontend - Environment Variables
# ===========================================

# Supabase Configuration
# ---------------------
# Get these from your Supabase project settings
# https://app.supabase.com/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# API Configuration
# ---------------------
# Backend API URL (use http://localhost:8000 for local development)
NEXT_PUBLIC_API_URL=http://localhost:8000

# Stripe Configuration
# ---------------------
# Get your publishable key from https://dashboard.stripe.com/apikeys
# Use test keys (pk_test_) for development
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key_here

# ===========================================
# Optional: Additional Settings
# ===========================================

# Analytics (future use)
# NEXT_PUBLIC_GA_TRACKING_ID=G-XXXXXXXXXX

# Sentry (future use)
# NEXT_PUBLIC_SENTRY_DSN=your_sentry_dsn_here

# App URL (for production deployments)
# NEXT_PUBLIC_APP_URL=https://sitesmith.app
