# ===========================================
# SiteSmith Backend API - Environment Variables
# ===========================================

# Application Settings
# ---------------------
APP_NAME=SiteSmith API
APP_VERSION=0.1.0
DEBUG=False

# Supabase Configuration
# ---------------------
# Get these from your Supabase project settings
# https://app.supabase.com/project/_/settings/api
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_KEY=your_supabase_service_role_key_here

# OpenAI Configuration
# ---------------------
# Get your API key from https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your_openai_api_key_here

# Stripe Configuration
# ---------------------
# Get these from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret_here

# Vercel Configuration
# ---------------------
# Get your API token from https://vercel.com/account/tokens
VERCEL_API_TOKEN=your_vercel_api_token_here
VERCEL_TEAM_ID=your_vercel_team_id_here

# CORS Configuration
# ---------------------
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# ===========================================
# Optional: Additional Settings
# ===========================================

# Rate Limiting (future use)
# RATE_LIMIT_PER_HOUR=100

# Logging Level (future use)
# LOG_LEVEL=INFO

# Redis Configuration (future use)
# REDIS_URL=redis://localhost:6379
